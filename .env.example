# PostgreSQL (Railway provides this automatically when you add a Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generate a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Admin registration code (set this to a secret phrase)
ADMIN_CODE=your_admin_code_here

# App URL (used for Stripe redirect after checkout)
APP_URL=https://cleanalert-production.up.railway.app

# Port (Railway sets this automatically — don't change)
PORT=3000
